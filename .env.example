# Runtime Diagnostics / Organ9 standalone server
PORT=4391

# Optional: absolute path to Chrome or Edge when auto-detection fails.
# TICKET_SNIPER_BROWSER=C:\Program Files\Google\Chrome\Application\chrome.exe

# Authorize.Net Accept Hosted checkout.
AUTHORIZE_NET_ENVIRONMENT=sandbox
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_SIGNATURE_KEY=
AUTHORIZE_NET_MERCHANT_NAME=Organ9
AUTHORIZE_NET_MERCHANT_PORTAL_URL=https://sandbox.authorize.net/
AUTHORIZE_NET_SUCCESS_URL=http://127.0.0.1:4391/runtime-diagnostics.html?checkout=success
AUTHORIZE_NET_CANCEL_URL=http://127.0.0.1:4391/runtime-diagnostics.html?checkout=cancel

AUTHORIZE_NET_STARTER_AMOUNT=499.00
AUTHORIZE_NET_PROFESSIONAL_AMOUNT=1999.00
AUTHORIZE_NET_ENTERPRISE_AMOUNT=12000.00
AUTHORIZE_NET_DEV_MODE_PRO_AMOUNT=799.00
AUTHORIZE_NET_EXTENDED_RETENTION_AMOUNT=499.00
AUTHORIZE_NET_TEAM_SEATS_AMOUNT=199.00
AUTHORIZE_NET_EXPORTS_API_AMOUNT=699.00
AUTHORIZE_NET_STRUCTURE_MONITOR_AMOUNT=4000.00
AUTHORIZE_NET_PERFORMANCE_SPECTRUM_AMOUNT=2500.00
AUTHORIZE_NET_UPDATE_RADAR_AMOUNT=1500.00
AUTHORIZE_NET_RISK_SCORE_ENGINE_AMOUNT=5000.00
AUTHORIZE_NET_AI_ACTIVITY_DETECTOR_AMOUNT=6000.00

# Optional display labels for the Plans page.
AUTHORIZE_NET_STARTER_PRICE_LABEL=$499/mo
AUTHORIZE_NET_PROFESSIONAL_PRICE_LABEL=$1,999/mo
AUTHORIZE_NET_ENTERPRISE_PRICE_LABEL=From $12,000/mo
AUTHORIZE_NET_STRUCTURE_MONITOR_PRICE_LABEL=From $4,000/mo
AUTHORIZE_NET_PERFORMANCE_SPECTRUM_PRICE_LABEL=$2,500/mo
AUTHORIZE_NET_UPDATE_RADAR_PRICE_LABEL=$1,500/mo
AUTHORIZE_NET_RISK_SCORE_ENGINE_PRICE_LABEL=From $5,000/mo
AUTHORIZE_NET_AI_ACTIVITY_DETECTOR_PRICE_LABEL=From $6,000/mo
AUTHORIZE_NET_DEV_MODE_PRO_PRICE_LABEL=$799/mo add-on
AUTHORIZE_NET_EXTENDED_RETENTION_PRICE_LABEL=$499/mo add-on
AUTHORIZE_NET_TEAM_SEATS_PRICE_LABEL=$199/seat/mo
AUTHORIZE_NET_EXPORTS_API_PRICE_LABEL=$699/mo add-on
